<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background_dark">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recent Notes"
        android:textColor="#C4956A"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/note_title_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#E6E1E5"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingVertical="4dp" />

    <TextView
        android:id="@+id/note_title_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#E6E1E5"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingVertical="4dp" />

    <TextView
        android:id="@+id/note_title_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#E6E1E5"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingVertical="4dp" />
</LinearLayout>
