# AnyNote Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL
POSTGRES_PASSWORD=anynote_dev

# JWT
JWT_SECRET=change-me-to-a-random-string-in-production

# Server Master Encryption Key (for encrypting user API keys)
MASTER_ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string

# LLM API Keys (server default provider)
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Flutter API base URL
API_BASE_URL=http://localhost:8080
