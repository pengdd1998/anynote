# ──────────────────────────────────────────────────────────────
# AnyNote Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#
# For development: most defaults work out of the box.
# For production:  ALL variables marked [REQUIRED] must be set.
# ──────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
# Password for the anynote database user.
# [REQUIRED in production]
POSTGRES_PASSWORD=anynote_dev

# ── Server ────────────────────────────────────────────────────
# Port the API server listens on (inside container and on host).
PORT=8080

# ── Authentication ────────────────────────────────────────────
# Secret key for signing JWT tokens.
# [REQUIRED] Minimum 16 characters. Use a cryptographically random string.
#   Example: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-string-in-production

# Master encryption key for encrypting user-stored API keys at rest (AES-256-GCM).
# [REQUIRED] Minimum 16 characters. Use a 32-byte hex string.
#   Example: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string

# ── MinIO (Object Storage) ───────────────────────────────────
# Access and secret keys for MinIO (S3-compatible storage).
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── LLM API Keys (optional) ─────────────────────────────────
# Server-side default/fallback LLM providers for AI proxy.
# When set, these configure the built-in DeepSeek (default) and Qwen (fallback) providers.
# Users can also configure their own LLM keys from the app, bypassing these.
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Logging ──────────────────────────────────────────────────
# Log level: debug, info, warn, error
LOG_LEVEL=info
# Log format: json (default) or text
# LOG_FORMAT=json

# ── CORS / WebSocket ────────────────────────────────────────
# Comma-separated list of allowed origins (replaces YAML allow_origins).
# WS_ALLOWED_ORIGINS=https://app.example.com,http://localhost:3000

# ── Chrome (headless browser for publishing) ────────────────
# CHROME_WS_URL=ws://localhost:9222

# ── Firebase Cloud Messaging ────────────────────────────────
# Path to Firebase service account JSON (enables push notifications).
# FIREBASE_CREDENTIALS_FILE=

# ── Flutter / Client ─────────────────────────────────────────
# Base URL the Flutter app uses to reach the API server.
API_BASE_URL=http://localhost:8080

# ── Version (used by Docker builds) ──────────────────────────
VERSION=dev
COMMIT=none
